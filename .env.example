# Copy to .env and fill in real values. Never commit .env.

# --- Postgres ---
POSTGRES_USER=engagement_admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=engagements
POSTGRES_PORT=5432
DATABASE_URL=postgres://engagement_admin:changeme@db:5432/engagements

# --- Backend ---
BACKEND_PORT=8080
CRED_ENC_KEY=changeme-32-byte-key-for-credential-encryption

# --- Nginx ---
HTTPS_PORT=443
# Only used by docker-compose.prod.yml: directory with fullchain.pem/privkey.pem
# to bind-mount over the self-signed dev cert. See README.md "TLS certificates".
PROD_CERTS_DIR=./prod-certs
